# Gremlin API Configuration
GREMLIN_API_KEY=your_gremlin_api_key_here
GREMLIN_TEAM_ID=your_gremlin_team_id_here

# AWS Credentials (for S3 log storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_SESSION_TOKEN=your_aws_session_token_here
S3_RESULTS_BUCKET=your-s3-results-bucket-name

# GitHub Credentials (for Jenkins pipeline)
GITHUB_USERNAME=your_github_username_here
GITHUB_TOKEN=your_github_token_here

# Kubernetes Target Configuration
K8S_NAMESPACE=your-k8s-namespace
K8S_CLUSTER=your-k8s-cluster-name
K8S_NAMESPACES=namespace-mgmt,namespace-func
TARGET_SERVICES=service-a,service-b
TARGET_HOST_IDS=i-0000000000000000a,i-0000000000000000b
IGNORE_SERVICES=service-to-ignore-a,service-to-ignore-b

# Local Development Paths
GITHUB_REPO_PATH=../../env_repo/
CONTAINER_SERVICE_MAPPING_PATH=../../ccgf_repo/platform-deployment-config/container-service-mapping.json
